<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MACAU 2D LIVE</title>
    
    <style>
        body {
            background: radial-gradient(circle, #4b0000 0%, #000000 100%);
            color: #ffffff;
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        .coin {
            position: fixed;
            top: -60px;
            z-index: -1;
            pointer-events: none;
            animation: fall linear infinite;
            background: transparent !important;
            display: block;
        }

        @keyframes fall {
            0% {
                transform: translateY(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.5;
            }
            90% {
                opacity: 0.5;
            }
            100% {
                transform: translateY(110vh) rotate(720deg);
                opacity: 0;
            }
        }

        .app-header {
            padding: 30px 10px 10px 10px;
            width: 100%;
            text-align: center;
        }

        .app-name {
            font-family: 'Times New Roman', serif;
            font-weight: 900;
            font-size: 48px;
            letter-spacing: 4px;
            margin: 0;
        }
/* Main Display (အလယ်က ကြီးတဲ့ အဝိုင်း) */
        #main-display {
            width: 210px;
            height: 210px;
            background: radial-gradient(circle, #1a1a1a, #000000);
            border: 5px solid #d4af37;
            border-radius: 50%;
            box-shadow: 
                0 0 40px rgba(212, 175, 55, 0.4),
                inset 0 0 20px rgba(212, 175, 55, 0.2);
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 20px 0;
        }

        .main-number {
            font-size: 110px;
            font-weight: bold;
            color: #ffffff;
            text-shadow: 3px 3px 10px #000000;
        }

        /* Update Bar */
        .update-bar {
            background: rgba(0, 0, 0, 0.85);
            padding: 8px 22px;
            border-radius: 50px;
            border: 1.5px solid #d4af37;
            font-size: 14px;
            font-weight: bold;
            color: #ffffff;
            margin-bottom: 30px;
        }

        /* Grid Container (၄ ချိန်ရဲ့ ကတ်တွေ) */
        #grid-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            padding: 0 20px 20px;
            width: 100%;
            max-width: 480px;
        }

        .card {
            background: #0d0d0d;
            border: 1.2px solid #d4af37;
            border-radius: 14px;
            overflow: hidden;
        }

        .time-label {
            background: linear-gradient(to right, #bf953f, #fcf6ba, #d4af37);
            color: #000000;
            font-weight: 900;
            padding: 12px 0;
            text-align: center;
            font-size: 16px;
        }

        .result-num {
            font-size: 46px;
            font-weight: 900;
            padding: 12px 0;
            color: #ffffff;
            text-align: center;
        }

        .data-row {
            display: flex;
            justify-content: space-around;
            padding: 10px;
            font-size: 11px;
            color: #d4af37;
        }

        .data-row span {
            display: flex;
            flex-direction: column;
            gap: 3px;
            font-weight: bold;
            color: #d4af37;
            text-align: center;
        }

        .data-row.small {
            color: #ffffff;
            font-size: 13px;
            font-weight: bold;
        }

    </style>
</head>

<body>
    </style>
</head>
